  "main": "src/index.js",
  "bugs": {
    "url": "https://github.com/andornaut/amp-media-player/issues"
  },
  "homepage": "https://github.com/andornaut/amp-media-player#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/andornaut/amp-media-player.git"
  },
  "type": "module",
  "dependencies": {
    "http-basic-auth-proxy-worker": "0.2.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "statezero": "^0.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-sort-destructure-keys": "^3.0.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3"
  },
  "scripts": {
    "build": "node build.mjs",
    "build:prod": "node build.mjs --production",
    "format": "prettier --write '{src/**/,tests/**/,./}*.{css,js,json,jsx,md,mjs}' && eslint --fix .",
    "lint": "eslint --max-warnings 0 .",
